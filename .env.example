DATABASE_URL=postgresql://postgres:<your_password>@localhost:5432/homesync
JWT_SECRET=replace-this-with-a-long-random-secret
NODE_ENV=production
ALLOWED_ORIGINS=https://yourdomain.com

# Zillow (RapidAPI) – used only for manual listing imports by a single developer.
# Do NOT set these in shared environments or expose them to the frontend.
ZILLOW_API_KEY=
ZILLOW_API_HOST=private-zillow.p.rapidapi.com
ALLOW_ZILLOW_IMPORT=yes